{
	"include": [
		"**/*",
		"**/.server/**/*",
		"**/.client/**/*",
		".react-router/types/**/*",
		"../../eatly/dist",
		"../../eatly/dist",
		"../../eatly/dist",
		"../../eatly/dist",
		"../../eatly/dist",
		"../../eatly/dist",
		"../../eatly/dist",
		"../../eatly/client",
		"../../eatly/dist",
		"../../eatly/dist"
	],
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"types": ["vite/client"],
		"skipLibCheck": true,

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",

		"rootDirs": [".", "./.react-router/types"],
		// "baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		},

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"erasableSyntaxOnly": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,

		/* Allow JS files */
		"allowJs": true,
		"checkJs": false
	}
	// "include": ["src"]
}
